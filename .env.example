# Google Gemini API key for the AI learning plan feature.
# Get one at https://aistudio.google.com/apikey
#
# NOTE: no EXPO_PUBLIC_ prefix — this is a SERVER-only variable used by the
# Expo Router API route (app/api/plan+api.ts). It is not bundled into the app.
# Copy this file to `.env`, fill in your key, then restart the dev server.
GEMINI_API_KEY=your_gemini_api_key_here

# Production only: the deployed API origin (e.g. an EAS Hosting URL) that serves
# the API routes. Leave unset in development — the app uses the Expo dev server.
# EXPO_PUBLIC_API_URL=https://your-deployment.example.com
